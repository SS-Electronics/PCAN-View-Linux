# ------------------------------------------------------------------ #
# PCAN-View Linux – .gitignore                                         #
# ------------------------------------------------------------------ #

# Build output (all compiler artefacts live here)
/build/

# ------------------------------------------------------------------ #
# C / GCC                                                              #
# ------------------------------------------------------------------ #
*.d
*.o
*.ko
*.obj
*.elf
*.gch
*.pch
*.su
*.i*86
*.x86_64

# Libraries
*.lib
*.a
*.la
*.lo
*.dll
*.so
*.so.*
*.dylib

# Linker output
*.ilk
*.map
*.exp

# Executables (catch stray binaries outside build/)
*.exe
*.out
*.app
*.hex

# Debug symbols
*.dSYM/
*.idb
*.pdb

# ------------------------------------------------------------------ #
# Kernel module artefacts                                              #
# ------------------------------------------------------------------ #
*.mod*
*.cmd
.tmp_versions/
modules.order
Module.symvers
Mkfile.old
dkms.conf

# ------------------------------------------------------------------ #
# Editors & IDEs                                                       #
# ------------------------------------------------------------------ #
# VS Code – keep c_cpp_properties.json (IntelliSense config), ignore workspace state
.vscode/settings.json
.vscode/*.code-workspace
.vscode/.browse.VC.db*

# CLion / JetBrains
.idea/
cmake-build-*/

# Vim / Neovim
*.swp
*.swo
*~

# Emacs
\#*\#
.\#*

# ------------------------------------------------------------------ #
# OS                                                                   #
# ------------------------------------------------------------------ #
.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------------------------------ #
# Trace files (user-generated, not part of the repo)                  #
# ------------------------------------------------------------------ #
*.csv
*.trc

# ------------------------------------------------------------------ #
# Tooling / language-server caches                                    #
# ------------------------------------------------------------------ #
compile_commands.json
.cache/
.clangd/
.ccls-cache/
tags
TAGS
cscope.*

# ------------------------------------------------------------------ #
# Logs & local scratch                                                #
# ------------------------------------------------------------------ #
*.log
*.xwd
/stage/
/staging/
/dist/

# ------------------------------------------------------------------ #
# Packaging output                                                    #
# ------------------------------------------------------------------ #
*.deb
*.rpm
*.AppImage
*.tar.gz
*.tar.xz
*.zip
